# {{ ansible_managed }}

---
services:
  mtgproxy:
    image: "{{ mtgproxy_docker_image }}"
    container_name: "{{ mtgproxy_docker_container_name }}"
    restart: unless-stopped
    environment:
      TZ: "{{ mtgproxy_docker_timezone }}"
    volumes:
      - {{ mtgproxy_docker_conf_file }}:/config/config.toml
{% for v in mtgproxy_docker_extra_volumes %}
      - {{ v }}
{% endfor %}
    network_mode: host
{% if mtgproxy_docker_compose_extra_conf %}
{{ mtgproxy_docker_compose_extra_conf | to_yaml(indent=2, default_flow_style=False) | indent(4, true) }}
{% endif %}
